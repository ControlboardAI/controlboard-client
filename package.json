{
  "name": "controlboard-client",
  "version": "1.5.0",
  "private": true,
  "description": "The ControlBoard client: the cb CLI and the ControlBoard MCP server, exactly as served from controlboard.ai, plus the macOS menubar app.",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check": "tsc --noEmit",
    "build": "pnpm build:cli && pnpm build:mcp",
    "build:cli": "esbuild cli/cb.ts --platform=node --bundle --format=esm --outfile=dist/cb.mjs --define:__CB_VERSION__=\\\"$npm_package_version\\\" --banner:js=\"#!/usr/bin/env node\"",
    "build:mcp": "esbuild mcp/server.ts --platform=node --bundle --format=esm --outfile=dist/controlboard-mcp.mjs --define:__CB_VERSION__=\\\"$npm_package_version\\\" --banner:js=\"#!/usr/bin/env node\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.7.0"
  }
}
